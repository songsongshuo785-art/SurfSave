<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.myAllVideoBrowser.ui.main.video.VideoViewModel" />

        <variable
            name="mainViewModel"
            type="com.myAllVideoBrowser.ui.main.home.MainViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/sxSurface">

        <LinearLayout
            android:id="@+id/video_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/sx_toolbar_background"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_normal"
            android:paddingEnd="@dimen/padding_normal"
            android:paddingBottom="@dimen/padding_normal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:contentInsetStart="0dp"
                android:contentInsetEnd="0dp"
                app:contentInsetStart="0dp"
                app:contentInsetEnd="0dp"
                app:title="@string/title_video"
                app:titleTextColor="@color/sxTextPrimary" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/video_library_subtitle"
                android:textColor="@color/sxTextSecondary"
                android:textSize="@dimen/text_small" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/finished_native_ad_container"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:background="@android:color/transparent"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/video_header" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_video"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:padding="@dimen/padding_small"
            app:items="@{viewModel.localVideos}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/finished_native_ad_container" />

        <LinearLayout
            android:id="@+id/layout_empty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/padding_large"
            android:visibility="@{viewModel.localVideos.size() == 0 ? View.VISIBLE : View.GONE}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/video_header">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_empty_icon"
                android:layout_width="@dimen/progress_icon_size"
                android:layout_height="@dimen/progress_icon_size"
                android:adjustViewBounds="true"
                android:background="@drawable/sx_thumbnail_background"
                android:padding="@dimen/padding_small"
                android:scaleType="centerInside"
                android:src="@drawable/ic_empty"
                app:shapeAppearanceOverlay="@style/customImageViewRounded" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_empty_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_normal"
                android:text="@string/video_empty_message"
                android:textColor="@color/sxTextSecondary"
                android:textSize="@dimen/text_medium" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/anchor"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
