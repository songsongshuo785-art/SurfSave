<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <import type="com.myAllVideoBrowser.ui.main.proxies.ProxiesViewModel.SecureDnsProvider" />

        <variable
            name="viewModel"
            type="com.myAllVideoBrowser.ui.main.proxies.ProxiesViewModel" />

        <variable
            name="listener"
            type="com.myAllVideoBrowser.ui.component.adapter.ProxiesListener" />
    </data>

    <ScrollView
        android:id="@+id/proxies_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/sxSurface"
        android:fillViewport="true"
        tools:context=".ui.main.proxies.ProxiesFragment">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_normal">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:contentInsetStart="0dp"
                android:contentInsetEnd="0dp"
                app:contentInsetStart="0dp"
                app:contentInsetEnd="0dp"
                app:title="@string/proxy"
                app:titleTextColor="@color/sxTextPrimary" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/padding_normal"
                android:text="@string/proxies_subtitle"
                android:textColor="@color/sxTextSecondary"
                android:textSize="@dimen/text_small" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/sxSurfaceRaised"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="@dimen/elev_resting"
                app:strokeColor="@color/sxOutline"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="88dp"
                    android:padding="@dimen/padding_normal">

                    <ImageView
                        android:id="@+id/proxy_status_icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/sx_thumbnail_background"
                        android:contentDescription="@string/proxy"
                        android:padding="@dimen/padding_small"
                        android:src="@drawable/wifi_proxy_icon24"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/colorPrimary" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/proxy_status_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_normal"
                        android:layout_marginEnd="@dimen/padding_small"
                        android:text="@string/proxies"
                        android:textColor="@color/sxTextPrimary"
                        android:textSize="@dimen/text_medium"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/proxy_status_summary"
                        app:layout_constraintEnd_toStartOf="@id/turn_proxy"
                        app:layout_constraintStart_toEndOf="@id/proxy_status_icon"
                        app:layout_constraintTop_toTopOf="@id/proxy_status_icon"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/proxy_status_summary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_normal"
                        android:layout_marginTop="@dimen/padding_tiny"
                        android:layout_marginEnd="@dimen/padding_small"
                        android:text="@{viewModel.realProxyCount > 0 ? viewModel.realProxyCount + ` proxies in chain` : `No proxy set`}"
                        android:textColor="@color/sxTextSecondary"
                        android:textSize="@dimen/text_small"
                        app:layout_constraintBottom_toBottomOf="@id/proxy_status_icon"
                        app:layout_constraintEnd_toStartOf="@id/turn_proxy"
                        app:layout_constraintStart_toEndOf="@id/proxy_status_icon"
                        app:layout_constraintTop_toBottomOf="@id/proxy_status_title"
                        tools:text="2 proxies in chain" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/turn_proxy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="@{viewModel.isProxyOn}"
                        android:onCheckedChanged="@{(view, isChecked) -> listener.onProxyToggle(isChecked)}"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:thumbTint="@color/switch_thumb_selector"
                        app:trackDecorationTint="@color/colorAccentDark"
                        app:trackTint="@color/color_gray" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_normal"
                app:cardBackgroundColor="@color/sxSurfaceRaised"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="@dimen/elev_resting"
                app:strokeColor="@color/sxOutline"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_normal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/secure_dns"
                            android:textColor="@color/sxTextPrimary"
                            android:textSize="@dimen/text_medium"
                            android:textStyle="bold" />

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/turn_secure_dns"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="@{viewModel.isSecureDnsOn}"
                            android:onCheckedChanged="@{(view, isChecked) -> viewModel.setSecureDnsState(isChecked)}"
                            app:thumbTint="@color/switch_thumb_selector"
                            app:trackDecorationTint="@color/colorAccentDark"
                            app:trackTint="@color/color_gray" />
                    </LinearLayout>

                    <RadioGroup
                        android:id="@+id/secureDnsProviderRadioGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_small"
                        android:orientation="vertical"
                        android:visibility="@{viewModel.isSecureDnsOn ? View.VISIBLE : View.GONE}">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/cloudflareRadioButton"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:buttonTint="@color/colorPrimary"
                            android:checked="@{viewModel.selectedDnsProvider == SecureDnsProvider.CLOUDFLARE}"
                            android:onClick="@{() -> viewModel.setSecureDnsProvider(SecureDnsProvider.CLOUDFLARE)}"
                            android:text="@string/doh_cloudflare"
                            android:textColor="@color/sxTextPrimary" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/quad9RadioButton"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:buttonTint="@color/colorPrimary"
                            android:checked="@{viewModel.selectedDnsProvider == SecureDnsProvider.QUAD9}"
                            android:onClick="@{() -> viewModel.setSecureDnsProvider(SecureDnsProvider.QUAD9)}"
                            android:text="@string/doh_quad9"
                            android:textColor="@color/sxTextPrimary" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/adguardRadioButton"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:buttonTint="@color/colorPrimary"
                            android:checked="@{viewModel.selectedDnsProvider == SecureDnsProvider.ADGUARD}"
                            android:onClick="@{() -> viewModel.setSecureDnsProvider(SecureDnsProvider.ADGUARD)}"
                            android:text="@string/doh_ad_guard"
                            android:textColor="@color/sxTextPrimary" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/customDnsRadioButton"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:buttonTint="@color/colorPrimary"
                            android:checked="@{viewModel.selectedDnsProvider == SecureDnsProvider.CUSTOM}"
                            android:onClick="@{() -> viewModel.setSecureDnsProvider(SecureDnsProvider.CUSTOM)}"
                            android:text="@string/dns_custom"
                            android:textColor="@color/sxTextPrimary" />
                    </RadioGroup>

                    <LinearLayout
                        android:id="@+id/customDnsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_small"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="@{viewModel.selectedDnsProvider == SecureDnsProvider.CUSTOM &amp;&amp; viewModel.isSecureDnsOn ? View.VISIBLE : View.GONE}">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/customDnsInputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/dns_custom_url_hint"
                            app:errorEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/customDnsEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textUri"
                                android:text="@={viewModel.customDnsUrl}" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/saveCustomDnsButton"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_marginStart="@dimen/padding_small"
                            android:text="@string/save_proxy"
                            android:textColor="@color/colorPrimary"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/sxOutline" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_normal"
                app:cardBackgroundColor="@color/sxSurfaceRaised"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="@dimen/elev_resting"
                app:strokeColor="@color/sxOutline"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_normal">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/add_http_proxy"
                        android:textColor="@color/sxTextPrimary"
                        android:textSize="@dimen/text_medium"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/proxyTypeRadioGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_small"
                        android:orientation="horizontal">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/httpRadioButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:buttonTint="@color/colorPrimary"
                            android:checked="true"
                            android:text="@string/http"
                            android:textColor="@color/sxTextPrimary" />

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/socks5RadioButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:buttonTint="@color/colorPrimary"
                            android:text="@string/socks5"
                            android:textColor="@color/sxTextPrimary" />
                    </RadioGroup>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/host_hint"
                        app:errorEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/hostEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_small"
                        android:hint="@string/port_hint"
                        app:errorEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/portEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_small"
                        android:hint="@string/login_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/loginEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_small"
                        android:hint="@string/password_hint"
                        app:passwordToggleEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/passwordEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/addProxyButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="@dimen/padding_normal"
                        android:text="@string/add_proxy"
                        android:textColor="@color/white"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_normal"
                android:layout_marginBottom="@dimen/padding_normal"
                android:visibility="@{viewModel.realProxyCount > 0 ? View.VISIBLE : View.GONE}"
                app:cardBackgroundColor="@color/sxSurfaceRaised"
                app:cardCornerRadius="@dimen/corner_md"
                app:cardElevation="@dimen/elev_resting"
                app:strokeColor="@color/sxOutline"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/padding_normal"
                    android:paddingBottom="@dimen/padding_normal">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="@dimen/padding_normal"
                        android:paddingEnd="@dimen/padding_normal"
                        android:text="@string/current_proxy_chain"
                        android:textColor="@color/sxTextPrimary"
                        android:textSize="@dimen/text_medium"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/proxiesRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_small"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_proxies" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</layout>
