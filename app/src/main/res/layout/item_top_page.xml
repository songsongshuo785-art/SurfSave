<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="pageInfo"
            type="com.myAllVideoBrowser.data.local.room.entity.PageInfo" />

        <variable
            name="listener"
            type="com.myAllVideoBrowser.ui.component.adapter.TopPageAdapter.TopPagesListener" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="124dp"
        android:layout_margin="4dp"
        android:clickable="true"
        android:focusable="true"
        android:onClick="@{() -> listener.onItemClicked(pageInfo)}"
        app:cardBackgroundColor="@color/sxSurfaceRaised"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/sxOutline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/padding_normal">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_icon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/sx_thumbnail_background"
                android:padding="6dp"
                android:scaleType="centerInside"
                app:shapeAppearanceOverlay="@style/customImageViewRounded" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_small"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@{pageInfo.getTitleFiltered()}"
                android:textAlignment="center"
                android:textColor="@color/sxTextPrimary"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold"
                tools:text="Youtube" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</layout>
