<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="listener"
            type="com.myAllVideoBrowser.ui.component.adapter.CandidateFormatListener" />

        <variable
            name="download_candidate"
            type="String" />

        <variable
            name="is_candidate_selected"
            type="Boolean" />

        <variable
            name="videoInfo"
            type="com.myAllVideoBrowser.data.local.room.entity.VideoInfo" />

    </data>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_item"
        android:layout_width="164dp"
        android:layout_height="96dp"
        android:layout_marginEnd="@dimen/padding_small"
        android:checkable="true"
        android:checked="@{is_candidate_selected}"
        android:onClick="@{() -> listener.onSelectFormat(videoInfo, download_candidate)}"
        android:onLongClick="@{() -> listener.onFormatUrlShare(videoInfo, download_candidate)}"
        app:cardBackgroundColor="@color/sxSurfaceRaised"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:checkedIconTint="@color/colorPrimary"
        app:strokeColor="@{is_candidate_selected ? @color/colorPrimary : @color/sxOutline}"
        app:strokeWidth="@{is_candidate_selected ? 2 : 1}">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="@dimen/padding_small">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@string/download_candidate_section"
                    android:src="@drawable/verified_user_24px"
                    app:tint="@color/colorPrimary" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_tiny"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/sxTextPrimary"
                    android:textSize="@dimen/text_small"
                    android:textStyle="bold"
                    tools:text="1080p MP4" />
            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tv_data"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/padding_tiny"
                android:layout_weight="1"
                android:ellipsize="end"
                android:lineSpacingExtra="1dp"
                android:maxLines="3"
                android:textColor="@color/sxTextSecondary"
                android:textSize="@dimen/text_tiny"
                tools:text="MP4 video&#10;Size 42 MB&#10;Duration 01:25" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
</layout>
