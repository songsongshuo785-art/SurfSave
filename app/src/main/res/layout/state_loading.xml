<?xml version="1.0" encoding="utf-8"?>
<!--
    通用加载态组件（UI 批 1，批 2 接入 data binding）。
    include 后父 layout 用 android:visibility 控制显隐，用 app:subtitle 传可选说明。
-->
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="subtitle"
            type="String" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/spacing_xxl">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/state_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            app:indicatorSize="40dp"
            app:trackThickness="4dp" />

        <TextView
            android:id="@+id/state_subtitle"
            style="@style/TextAppearance.Surf.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:alpha="0.7"
            android:gravity="center"
            android:text="@{subtitle}"
            android:visibility="@{subtitle == null ? View.GONE : View.VISIBLE}" />
    </LinearLayout>
</layout>
