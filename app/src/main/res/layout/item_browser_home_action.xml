<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/home_action_card"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/sxSurfaceRaised"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:rippleColor="@color/colorPrimary_20"
        app:strokeColor="@color/sxOutline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/padding_small">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/sx_thumbnail_background">

                <ImageView
                    android:id="@+id/home_action_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:padding="9dp"
                    android:scaleType="centerInside"
                    app:tint="@color/colorPrimary"
                    tools:src="@drawable/tab_group_24px" />
            </FrameLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/home_action_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="2"
                android:textColor="@color/sxTextPrimary"
                android:textSize="@dimen/text_small"
                android:textStyle="bold"
                tools:text="@string/home_action_continue_session" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>
