<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ===== 深色：参照 Chrome 设计语言（中性深灰 + 卡片明显浮起 + Google 蓝）=====
         对症之前的"带蓝 slate + 卡片不浮起"：背景去蓝变 Chrome 标志中性深灰，
         卡片用 surfaceContainer 明显浮起，文字用 Chrome 中性白/灰。强调蓝保留品牌蓝亮版(≈Chrome blue)。 -->

    <color name="colorPrimary_20">#3393C5FD</color>
    <color name="colorPrimary">#93C5FD</color>
    <color name="colorPrimaryDark">#60A5FA</color>
    <!-- colorAccent 收敛到 primary 同色相 tonal -->
    <color name="colorAccent">#93C5FD</color>
    <color name="colorAccentDark">#60A5FA</color>

    <!-- Chrome 参照：中性深灰背景 + 明显浮起卡片层次（surface < raised < soft） -->
    <color name="sxSurface">#202124</color>
    <color name="sxSurfaceRaised">#303030</color>
    <color name="sxSurfaceSoft">#3C4043</color>
    <color name="sxSurfaceSelected">#1E3A8A</color>
    <color name="sxOutline">#5F6368</color>
    <color name="sxTextPrimary">#E8EAED</color>
    <color name="sxTextSecondary">#9AA0A6</color>

    <!-- 语义反馈色 (night) -->
    <color name="colorSuccess">#4CC38A</color>
    <color name="colorError">#FFB4AB</color>
    <color name="colorOnError">#690005</color>
    <color name="colorWarning">#FFB445</color>

    <!-- M3 tonal extensions on primary (night) -->
    <color name="colorOnPrimary">#062E6F</color>
    <color name="colorPrimaryContainer">#004A77</color>
    <color name="colorOnPrimaryContainer">#D3E3FF</color>
</resources>
